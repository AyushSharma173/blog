---
import { marked } from "marked";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
  SITE_TITLE, HOME_HEADING, HOME_BIO,
  HOME_FONT, HOME_BIO_FONT,
  HOME_BIO_SIZE, HOME_BIO_ITALIC, HOME_BIO_WEIGHT, HOME_BIO_ALIGN,
} from "../consts";

const bioHtml = marked.parse(HOME_BIO, { gfm: true, breaks: true, async: false }) as string;

const bioClasses = [
  "intro-bio",
  `font-${HOME_BIO_FONT}`,
  HOME_BIO_SIZE,
  HOME_BIO_ITALIC ? "italic" : "",
  HOME_BIO_WEIGHT === "semibold" ? "font-semibold" : "",
  HOME_BIO_ALIGN !== "left" ? `text-${HOME_BIO_ALIGN}` : "",
].filter(Boolean).join(" ");

const allPosts = await getCollection("posts", ({ data }) =>
  import.meta.env.DEV || !data.draft
);

const posts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const fmtMonthDay = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "2-digit" });
---
<BaseLayout title={SITE_TITLE} bodyClass={`font-${HOME_FONT}`}>
  <header class="intro">
    <h1>{HOME_HEADING}</h1>
    <div class={bioClasses} set:html={bioHtml}></div>
    <p><a href="/about/">About →</a></p>
  </header>

  <section class="writing">
    <h2>Writing</h2>
    {years.map((year) => (
      <div>
        <h3>{year}</h3>
        <ul class="post-list">
          {byYear.get(year)!.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString().split("T")[0]}>
                {fmtMonthDay(post.data.date)}
              </time>
              <a href={`/writing/${post.slug}/`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>
